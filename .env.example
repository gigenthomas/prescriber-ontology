POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ontology
POSTGRES_USER=ontology
POSTGRES_PASSWORD=ontology

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ontology-dev

# Keycloak (OIDC identity provider). Default password matches docker-compose
# defaults so `docker compose up -d` brings up a working dev env out of the box.
KEYCLOAK_ADMIN_PASSWORD=keycloak-dev
# Optional: a service-account bearer token the MCP server requires for tools/call.
# Leave unset to run MCP in implicit-admin mode (existing local-dev behavior).
# MCP_SERVICE_TOKEN=

# Optional: explicit auth provider. When AUTH_PROVIDER=keycloak the Go web
# server enforces login; default 'none' preserves the prior unauthenticated UX.
# AUTH_PROVIDER=keycloak

MESH_YEAR=2025
DATA_DIR=./data
