# ─── Databases ──────────────────────────────────────────────────────────────

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ontology
POSTGRES_USER=ontology
POSTGRES_PASSWORD=ontology

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ontology-dev

# ─── LLM API keys ───────────────────────────────────────────────────────────

# Required: Anthropic API key for the chatbot / MCP server.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: model override (default claude-sonnet-4-6).
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: OpenAI API key for pgvector semantic-search embeddings.
# Required only when running `ontology embed` or using the semantic_search tool.
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── HTTP server ────────────────────────────────────────────────────────────

# Optional: chatbot bind address (default :8080).
# ADDR=:8081

# ─── Auth + policy (optional — all defaults preserve the prior unauthenticated UX) ───
#
# Set AUTH_PROVIDER=keycloak to enable OIDC login + OPA policy enforcement
# on every tool call. The other KEYCLOAK_* and OPA_URL values match the
# defaults baked into docker-compose.yml; override only if you point at a
# non-local Keycloak / OPA instance.

# AUTH_PROVIDER=keycloak
# KEYCLOAK_ADMIN_PASSWORD=keycloak-dev
# KEYCLOAK_ISSUER_URL=http://localhost:8180/realms/ontology-dev
# KEYCLOAK_CLIENT_ID=ontology-web
# KEYCLOAK_CLIENT_SECRET=
# KEYCLOAK_REDIRECT_URL=http://localhost:8081/auth/callback
# OPA_URL=http://localhost:8181

# Set KEYCLOAK_DISCOVERY_URL when the bot reaches Keycloak at a different URL
# than the browser does — the docker-compose `bot` service runs in the
# compose network, so it hits Keycloak at http://keycloak:8080 internally
# while the browser still uses http://localhost:8180. Leave unset for the
# host-launched workflow (defaults to KEYCLOAK_ISSUER_URL).
# KEYCLOAK_DISCOVERY_URL=http://keycloak:8080/realms/ontology-dev

# ─── MCP service account ────────────────────────────────────────────────────
#
# When auth is enabled, MCP calls run as a synthetic service-account identity
# so the same OPA policies apply. All have defaults; override to grant a
# narrower / wider role set or change the synthetic identity.

# MCP_SERVICE_TOKEN=                          # optional bearer required for MCP tools/call
# MCP_SERVICE_SUB=00000000-0000-0000-0000-00000000mcp1
# MCP_SERVICE_USERNAME=mcp-service
# MCP_SERVICE_ROLES=compliance,analyst,viewer

# ─── Misc ───────────────────────────────────────────────────────────────────

MESH_YEAR=2025
DATA_DIR=./data

# Optional overrides for the YAML / queries the chatbot loads (default ./).
# ONTOLOGY_QUERIES_DIR=./queries
# ONTOLOGY_METRICS_FILE=./metrics.yaml
# ONTOLOGY_ACTIONS_FILE=./actions.yaml
